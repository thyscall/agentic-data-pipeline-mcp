        ce.product_category,
        ce.ad_strategy,
        case 
            when ce.campaign_id is not null then 1 else 0
        end as is_campaign_conversion

    from sales_orders so
    left join campaign_events ce
        on so.sales_order_id = ce.order_id
)

select * from campaign_join
  )
